{
	"mcpServers": {
		"serena": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"--from",
				"git+https://github.com/oraios/serena",
				"serena",
				"start-mcp-server",
				"--mode",
				"one-shot",
				"--mode",
				"editing",
				"--context",
				"claude-code"
			],
			"env": {}
		},
		"shadcn": {
			"command": "npx",
			"args": ["shadcn@latest", "mcp"]
		}
	}
}
